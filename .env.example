# ─── CityCab environment configuration ───
# Copy this file to `.env` and fill in your own values.
# The real .env is git-ignored and must never be committed.

# Flask session-signing key. Use a long, random string in production.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Database URL (SQLAlchemy format).
# Defaults to a local SQLite database in ./instance/citycab.db if omitted.
# Examples:
#   sqlite:///citycab.db
#   postgresql+psycopg2://user:password@localhost:5432/citycab
DATABASE_URL=sqlite:///citycab.db

# Set to 1 to enable Flask's debug mode locally. Leave 0 (default) in production.
FLASK_DEBUG=0
